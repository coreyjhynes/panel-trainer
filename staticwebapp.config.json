{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.css", "/*.js", "/*.md", "/scenarios.html"]
  },
  "routes": [
    { "route": "/api/*", "methods": ["GET", "POST", "DELETE", "OPTIONS"], "allowedRoles": ["anonymous"] }
  ],
  "mimeTypes": {
    ".md": "text/markdown",
    ".json": "application/json"
  }
}
